{
    "version": "8.21.0_1",
    "description": "Command line tool and library for transferring data with URLs",
    "homepage": "https://curl.se/",
    "license": "MIT",
    "depends": "findlinks",
    "architecture": {
        "64bit": {
            "url": "https://curl.se/windows/dl-8.21.0_1/curl-8.21.0_1-win64-mingw.tar.xz",
            "hash": "237cd50d5d29cd96f38798db722c11bf5dbe5451e3fa6e505077e933354c4fae",
            "extract_dir": "curl-8.21.0_1-win64-mingw"
        },
        "arm64": {
            "url": "https://curl.se/windows/dl-8.21.0_1/curl-8.21.0_1-win64a-mingw.tar.xz",
            "hash": "302f8455c39b96c45bb48cb333931cba36847fe2df3b77b384ef6a5569f9e33e",
            "extract_dir": "curl-8.21.0_1-win64a-mingw"
        }
    },
    "bin": "bin\\curl.exe",
    "checkver": {
        "url": "https://curl.se/windows/",
        "regex": "Build<\\/b>:\\s+([\\d._]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://curl.se/windows/dl-$version/curl-$version-win64-mingw.tar.xz",
                "extract_dir": "curl-$version-win64-mingw"
            },
            "arm64": {
                "url": "https://curl.se/windows/dl-$version/curl-$version-win64a-mingw.tar.xz",
                "extract_dir": "curl-$version-win64a-mingw"
            }
        },
        "hash": {
            "url": "$baseurl/hashes.txt",
            "regex": "SHA2-256\\($basename\\)=\\s+$sha256"
        }
    },
    "post_install": [
        "# Append CA patch to $dir\\bin\\curl-ca-bundle.crt if it exists",
        "if (Test-Path \"$persist_dir\\curl-ca-bundle.patch\") {",
        "   $patch = Get-Content \"$persist_dir\\curl-ca-bundle.patch\"",
        "   $caBundle = Get-Content \"$dir\\bin\\curl-ca-bundle.crt\"",
        "   $caBundle += $patch",
        "   $caBundle | Set-Content \"$dir\\bin\\curl-ca-bundle.crt\"",
        "}"
    ],
    "notes": [
        "If you need to add additional CA to the default bundle, you can create curl-ca-bundle.patch in the persist directory.",
        "The content of the patch will be appended to $dir\\bin\\curl-ca-bundle.crt after installation.",
        "This often defaults to $HOME\\Scoop\\persist\\curl\\"
    ]
}
